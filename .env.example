# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ── TMDB credentials (https://www.themoviedb.org/settings/api) ───────────────
TMDB_BASE_URL=https://api.themoviedb.org/3

# Bearer token (v4 read-access token) — recommended, works for all v3 endpoints
TMDB_BEARER_TOKEN=your_tmdb_bearer_token_here

# API key (v3) — only used when TMDB_BEARER_TOKEN is not set
TMDB_API_KEY=your_tmdb_api_key_here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * to allow all.
CORS_ORIGIN=http://localhost:4200

# ── Client authentication ─────────────────────────────────────────────────────
# Secret key that clients must send in the x-api-key header.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CLIENT_API_KEY=your_client_api_key_here

